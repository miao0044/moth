{
  "name": "moth",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "start": "node esbuild.config.mjs && electron .",
    "dist": "node esbuild.config.mjs && electron-builder --win"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "codemirror": "^6.0.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.moth.editor",
    "productName": "Moth",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "style.css",
      "dist/**/*",
      "!dist/*.map"
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico"
    },
    "fileAssociations": [
      {
        "ext": "txt",
        "name": "Text File",
        "description": "Text File",
        "role": "Editor"
      },
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown File",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown File",
        "role": "Editor"
      },
      {
        "ext": "json",
        "name": "JSON File",
        "description": "JSON File",
        "role": "Editor"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
